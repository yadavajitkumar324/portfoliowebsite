:root {
  font-family: 'Trebuchet MS', 'Aptos', 'Segoe UI', sans-serif;
  color: #f7f4ea;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 63, 0.16), transparent 28%),
    radial-gradient(circle at 85% 15%, rgba(255, 140, 63, 0.12), transparent 24%),
    linear-gradient(180deg, #07111f 0%, #0b172a 55%, #101d31 100%);
  --canvas: rgba(8, 18, 34, 0.78);
  --canvas-strong: rgba(12, 27, 49, 0.92);
  --line: rgba(255, 255, 255, 0.08);
  --text-soft: #c2cad8;
  --accent: #ff8c3f;
  --accent-strong: #ff6b00;
  --ice: #ffb347;
  --success: #86efac;
  --danger: #fca5a5;
}

:root[data-theme="light"] {
  color: #1a1a1a;
  background:
    radial-gradient(circle at top left, rgba(255, 140, 63, 0.12), transparent 28%),
    radial-gradient(circle at 85% 15%, rgba(255, 140, 63, 0.08), transparent 24%),
    linear-gradient(180deg, #f5f5f5 0%, #ffffff 55%, #fafafa 100%);
  --canvas: rgba(245, 245, 245, 0.9);
  --canvas-strong: rgba(240, 240, 240, 0.98);
  --line: rgba(0, 0, 0, 0.08);
  --text-soft: #666666;
  --accent: #ff8c3f;
  --accent-strong: #ff6b00;
  --ice: #ff9955;
  --success: #22c55e;
  --danger: #ef4444;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  margin: 0;
  min-width: 320px;
  color: #f7f4ea;
  background:
    radial-gradient(circle at top left, rgba(246, 180, 72, 0.16), transparent 28%),
    radial-gradient(circle at 85% 15%, rgba(49, 118, 232, 0.18), transparent 24%),
    linear-gradient(180deg, #07111f 0%, #0b172a 55%, #101d31 100%);
}

:root[data-theme="light"] body {
  color: #1a1a1a;
  background:
    radial-gradient(circle at top left, rgba(246, 180, 72, 0.08), transparent 28%),
    radial-gradient(circle at 85% 15%, rgba(49, 118, 232, 0.08), transparent 24%),
    linear-gradient(180deg, #f5f5f5 0%, #ffffff 55%, #fafafa 100%);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
textarea {
  font: inherit;
}

#root {
  min-height: 100vh;
}

.page-shell {
  position: relative;
  overflow: hidden;
  transition: background 300ms ease;
}

.ambient {
  position: fixed;
  z-index: 0;
  width: 26rem;
  height: 26rem;
  border-radius: 999px;
  filter: blur(28px);
  opacity: 0.45;
  pointer-events: none;
}

.ambient-left {
  top: 5rem;
  left: -9rem;
  background: rgba(255, 164, 72, 0.22);
  animation: drift 12s ease-in-out infinite;
}

.ambient-right {
  top: 14rem;
  right: -8rem;
  background: rgba(114, 209, 255, 0.18);
  animation: drift 16s ease-in-out infinite reverse;
}

.topbar,
main {
  position: relative;
  z-index: 1;
}

.topbar {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
  padding: 1.25rem 0 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.85rem;
  font-weight: 700;
}

.brand-mark {
  display: grid;
  place-items: center;
  width: 2.8rem;
  height: 2.8rem;
  border-radius: 1rem;
  background: linear-gradient(135deg, var(--accent), var(--accent-strong));
  color: #04101f;
  box-shadow: 0 14px 34px rgba(255, 140, 63, 0.28);
}

.brand-text {
  font-size: 18px;
  letter-spacing: 0.02em;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 1.15rem;
  color: var(--text-soft);
}

.nav-links a {
  transition: color 180ms ease;
}

.nav-links a:hover {
  color: #04101f;
}

:root[data-theme="light"] .nav-links a:hover {
  color: #000;
}

.theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2.2rem;
  height: 2.2rem;
  border-radius: 0.6rem;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--accent);`n  cursor: pointer;
  font-size: 1.1rem;
  transition: all 200ms ease;
  margin-left: 0.8rem;
}

.theme-toggle:hover {
  background: rgba(255, 255, 255, 0.15);
  border-color: rgba(255, 255, 255, 0.2);
  transform: scale(1.05);
}

:root[data-theme="light"] .theme-toggle {
  background: rgba(0, 0, 0, 0.08);
  border-color: rgba(0, 0, 0, 0.1);
  color: #ff8c3f;
}

main {
  width: min(1180px, calc(100% - 2rem));
  margin: 0 auto;
  padding-bottom: 4rem;
}

.section {
  padding: 4.75rem 0 0;
}

.hero {
  display: grid;
  grid-template-columns: 1.15fr 0.95fr;
  gap: 2rem;
  align-items: center;
  min-height: calc(100vh - 5rem);
}

.eyebrow,
.section-kicker,
.card-label {
  margin: 0 0 0.8rem;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  font-size: 0.74rem;
  color: var(--ice);
}

.blue-highlight {
  color: #63b3ff;
}

:root[data-theme="light"] .blue-highlight {
  color: #ff8c3f;
}

.hero h1,
.section h2,
.panel h3,
.identity-card h2 {
  margin: 0;
  font-family: Georgia, 'Times New Roman', serif;
  line-height: 0.96;
}

.hero h1 {
  font-size: clamp(2.2rem, 5.2vw, 4.1rem);
  max-width: 10ch;
}

.hero-title {
  margin: 1rem 0 0;
  color: var(--accent);`n  font-size: clamp(1.15rem, 2vw, 1.55rem);
  font-weight: 700;
}

.hero-text,
.panel p,
.detail-list,
.stack-item p,
.meta-line,
.contact-strip,
.contact-blocks {
  color: var(--text-soft);
  line-height: 1.7;
}

.hero-text {
  max-width: 60ch;
  margin: 1.1rem 0 0;
  font-size: 1.02rem;
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
  margin-top: 2rem;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 3.2rem;
  padding: 0 1.35rem;
  border-radius: 999px;
  border: 1px solid transparent;
  font-weight: 700;
  transition:
    transform 180ms ease,
    border-color 180ms ease,
    background 180ms ease;
}

.button:hover {
  transform: translateY(-2px);
}

.button.primary {
  color: #04101f;
  background: linear-gradient(135deg, var(--accent), var(--accent-strong));
  box-shadow: 0 14px 34px rgba(255, 140, 63, 0.28);
}

.button.secondary {
  border-color: rgba(255, 255, 255, 0.16);
  background: rgba(255, 255, 255, 0.04);
}

.button.explore {
  color: #eaf8ff;
  border-color: rgba(109, 216, 255, 0.55);
  background: linear-gradient(135deg, rgba(18, 110, 167, 0.8), rgba(56, 183, 235, 0.86));
  box-shadow: 0 12px 26px rgba(61, 169, 229, 0.26);
}

.button.cert-view {
  color: #f3f0ff;
  border-color: rgba(175, 149, 255, 0.6);
  background: linear-gradient(135deg, rgba(86, 58, 173, 0.85), rgba(126, 96, 217, 0.9));
}

.button.cert-download {
  color: #eafff2;
  border-color: rgba(90, 224, 152, 0.55);
  background: linear-gradient(135deg, rgba(13, 129, 79, 0.88), rgba(28, 173, 106, 0.92));
}

.button.contact-send {
  color: #fff2f4;
  background: linear-gradient(135deg, rgba(220, 80, 115, 0.95), rgba(255, 126, 98, 0.92));
  box-shadow: 0 14px 30px rgba(230, 96, 111, 0.28);
}

.contact-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem 1.5rem;
  padding: 0;
  margin: 1.5rem 0 0;
  list-style: none;
}

.hero-panel,
.panel {
  background: linear-gradient(180deg, rgba(16, 34, 58, 0.78), rgba(9, 20, 36, 0.92));
  border: 1px solid var(--line);
  border-radius: 1.75rem;
  backdrop-filter: blur(14px);
  box-shadow: 0 18px 56px rgba(1, 7, 16, 0.32);
}

:root[data-theme="light"] .hero-panel,
:root[data-theme="light"] .panel {
  background: linear-gradient(180deg, rgba(250, 250, 250, 0.85), rgba(245, 245, 245, 0.95));
  box-shadow: 0 18px 56px rgba(0, 0, 0, 0.08);
}

.hero-panel {
  padding: 1.5rem;
  display: grid;
  justify-items: center;
}

.panel {
  padding: 1.6rem;
}

.identity-card {
  display: flex;
  justify-content: center;
  width: 100%;
}

.avatar {
  width: 11rem;
  height: 11rem;
  border-radius: 50%;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.04);
  box-shadow: 0 16px 30px rgba(0, 0, 0, 0.28);
}

.avatar img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
}

.identity-card h2 {
  font-size: clamp(1.8rem, 3vw, 2.4rem);
}

.stats-grid {
  margin-top: 1.5rem;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}

.stat-card {
  padding: 1.1rem;
  border-radius: 1.3rem;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.stat-card strong {
  display: block;
  font-size: 1.8rem;
  color: #04101f;
}

.stat-card span {
  color: var(--text-soft);
}

.social-row {
  display: flex;
  gap: 0.8rem;
  margin-top: 1.2rem;
  flex-wrap: wrap;
}

.social-row a,
.contact-blocks a {
  color: var(--ice);
}

.about-grid,
.contact-layout {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1.4rem;
}

.checklist ul,
.detail-list {
  margin: 1rem 0 0;
  padding-left: 1.15rem;
}

.section-heading {
  max-width: 42rem;
  margin-bottom: 1.4rem;
}

.section-heading h2,
.panel h3 {
  font-size: clamp(1.25rem, 2vw, 1.7rem);
}

.skills-layout,
.education-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 1.4rem;
}

.horizontal-row {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(320px, 1fr);
  gap: 1.4rem;
  overflow-x: auto;
  padding-bottom: 0.35rem;
  scrollbar-width: thin;
}

.horizontal-card {
  min-height: 100%;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 0.7rem;
  margin-top: 1rem;
}

.chip {
  padding: 0.65rem 0.95rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.skill-chip {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.skill-icon-wrap {
  display: inline-flex;
  align-items: center;
  gap: 0.2rem;
  color: var(--accent);`n}

.skill-icon {
  font-size: 1.05rem;
}

.skill-icon.alt {
  opacity: 0.85;
}

.chip.muted {
  color: #eef4ff;
  background: rgba(92, 154, 255, 0.1);
}

.badge,
.meta-line {
  display: block;
}

.badge {
  color: var(--text-soft);
}

.project-card {
  display: grid;
  align-content: start;
}

.project-image-container {
  width: 100%;
  height: 180px;
  overflow: hidden;
  border-radius: 1rem;
  margin-bottom: 1rem;
  background: linear-gradient(135deg, rgba(255, 179, 71, 0.1), rgba(135, 215, 255, 0.1));
  border: 2px solid transparent;
  background-clip: padding-box;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.project-image-container::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, var(--accent), var(--ice));
  border-radius: 1rem;
  z-index: -1;
  opacity: 0.5;
}

.project-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.project-image-container::after {
  content: '📁';
  position: absolute;
  font-size: 2.5rem;
  opacity: 0.3;
  z-index: 0;
}

.project-header,
.stack-head {
  display: flex;
  align-items: start;
  justify-content: space-between;
  gap: 1rem;
}

.badge {
  padding: 0.55rem 0.8rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.06);
}

.stack-list {
  display: grid;
  gap: 0.9rem;
  margin-top: 1rem;
}

.certificates-panel {
  margin-top: 1.4rem;
}

.single-certificate-display {
  margin-top: 1rem;
  display: grid;
  grid-template-columns: 1fr;
}

.certificate-row {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(280px, 1fr);
  gap: 1rem;
  overflow-x: auto;
  padding-bottom: 0.35rem;
  scrollbar-width: thin;
  margin-top: 1rem;
}

.stack-item {
  padding: 1rem;
  border-radius: 1.2rem;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.certificate-card {
  display: grid;
  gap: 0.9rem;
  min-height: 100%;
}

.certificate-image-wrapper-half {
  width: 200%;
  height: 140px;
  border-radius: 0.8rem;
  overflow: hidden;
  background: linear-gradient(135deg, rgba(255, 140, 63, 0.15), rgba(255, 165, 0, 0.1));
  position: relative;
  border: 2px solid transparent;
  background-clip: padding-box;
  box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.certificate-image-wrapper-half::before {
  content: '';
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, rgba(255, 179, 71, 0.6), rgba(135, 215, 255, 0.6));
  border-radius: 0.8rem;
  z-index: -1;
  opacity: 0.8;
  animation: borderPulse 3s ease-in-out infinite;
}

.certificate-image-half {
  width: 50%;
  height: 100%;
  object-fit: cover;
  object-position: left;
  display: block;
  border-radius: 0.6rem;
}

.certificate-image-wrapper-half::after {
  content: '📜';
  position: absolute;
  font-size: 2.5rem;
  opacity: 0.3;
  z-index: 0;
  right: 20px;
}

.certificate-image-wrapper-half:has(img) {
  background-image: none;
}

.single-certificate-display {
  margin-top: 1rem;
}

@keyframes borderPulse {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 0.95;
  }
}

.certificate-meta {
  margin: 0.35rem 0 0;
}

.certificate-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-top: auto;
}

.certificate-button {
  min-height: 2.7rem;
  padding: 0 1rem;
}

.certificate-note {
  color: var(--ice);
  font-size: 0.95rem;
}

.stack-item.emphasis {
  background: rgba(255, 179, 71, 0.08);
}

.achievements-panel {
  margin-top: 1.4rem;
}

.achievement-row {
  margin-top: 1rem;
}

.achievement-card {
  min-width: 320px;
}

.stack-item p {
  margin-bottom: 0;
}

.contact-blocks {
  display: grid;
  gap: 0.75rem;
  margin-top: 1.35rem;
}

.contact-form {
  display: grid;
  gap: 1rem;
}

.contact-form label {
  display: grid;
  gap: 0.45rem;
  color: #f7f4ea;
}

.contact-form input,
.contact-form textarea {
  width: 100%;
  padding: 0.9rem 1rem;
  border-radius: 1rem;
  border: 1px solid rgba(255, 255, 255, 0.1);
  background: rgba(255, 255, 255, 0.04);
  color: #04101f;
  resize: vertical;
}

.contact-form input:focus,
.contact-form textarea:focus {
  outline: 2px solid rgba(135, 215, 255, 0.5);
  border-color: transparent;
}

.form-status {
  margin: 0;
  font-weight: 700;
}

.form-status.success {
  color: var(--success);
}

.form-status.error {
  color: var(--danger);
}

.reveal {
  animation: riseUp 0.8s ease both;
}

.rise-1 {
  animation-delay: 0.08s;
}

.rise-2 {
  animation-delay: 0.18s;
}

.rise-3 {
  animation-delay: 0.28s;
}

@keyframes riseUp {
  from {
    opacity: 0;
    transform: translateY(22px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes drift {
  0%,
  100% {
    transform: translate3d(0, 0, 0) scale(1);
  }

  50% {
    transform: translate3d(1rem, 1.5rem, 0) scale(1.06);
  }
}

@media (max-width: 980px) {
  .hero,
  .about-grid,
  .contact-layout,
  .skills-layout,
  .education-grid,
  .horizontal-row {
    grid-template-columns: 1fr;
  }

  .hero {
    min-height: auto;
    padding-top: 3rem;
  }

  .horizontal-row {
    grid-auto-flow: row;
    grid-auto-columns: unset;
    overflow-x: visible;
  }
}

@media (max-width: 720px) {
  .topbar {
    flex-direction: column;
    align-items: start;
  }

  .nav-links {
    flex-wrap: wrap;
    gap: 0.8rem 1rem;
  }

  .hero-actions,
  .contact-strip,
  .social-row {
    flex-direction: column;
    align-items: stretch;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }

  .identity-card {
    grid-template-columns: 1fr;
  }

  .certificate-row {
    grid-auto-columns: minmax(240px, 85vw);
  }

  .hero h1 {
    max-width: 100%;
  }
}


